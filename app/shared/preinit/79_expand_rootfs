#!/bin/sh
# /lib/preinit/79_expand_rootfs
# Unified rootfs partition and overlay filesystem auto-expansion.
#
# Runs every boot during preinit (before 80_mount_root mounts /overlay).
#
# Why preinit?
# 1. Zero reboots: Partition expansion and unmounted filesystem resize happen in one pass
#    before mount_root runs. On first boot, the router comes up 100% expanded.
# 2. Idempotent & stateless: Checks physical sector counts in /sys/class/block/ and skips
#    partition table operations if less than ~4MB free space remains.
# 3. F2FS compatible: f2fs does not support online resizing. In preinit, /overlay is not
#    yet mounted, allowing resize.f2fs to safely grow the filesystem offline.

log_msg() {
    echo "expand-rootfs: $*" > /dev/kmsg 2>/dev/null || true
    logger -t "expand-rootfs" "$*" 2>/dev/null || true
}

do_expand_rootfs() {
    if [ -f /etc/rootfs-expanded ] || [ -f /overlay/upper/etc/rootfs-expanded ] || [ -f /tmp/overlay/upper/etc/rootfs-expanded ]; then
        log_msg "Rootfs already expanded, skipping partition check."
        return 0
    fi

    log_msg "Starting rootfs partition expansion check..."

    # 1. Find physical (non-loop) block device backing root/overlay.
    #    NOTE: In preinit_main, /overlay is NOT yet mounted (that happens in 80_mount_root).
    #    We look for /rom (squashfs rootfs) or / as the anchor to identify the disk.
    #    The actual partition we expand may be the last partition on that disk.
    local target_dev
    target_dev="$(block info 2>/dev/null | grep 'MOUNT="/overlay"' | grep -v '^/dev/loop' | head -n 1 | cut -d: -f1)"
    if [ -z "$target_dev" ]; then
        target_dev="$(block info 2>/dev/null | grep 'MOUNT="/rom"' | grep -v '^/dev/loop' | head -n 1 | cut -d: -f1)"
    fi
    if [ -z "$target_dev" ]; then
        target_dev="$(block info 2>/dev/null | grep 'MOUNT="/"' | grep -v '^/dev/loop' | head -n 1 | cut -d: -f1)"
    fi
    if [ -z "$target_dev" ]; then
        # Last resort: find last partition on first non-loop disk via /sys
        local disk_name
        disk_name="$(ls /sys/class/block/ 2>/dev/null | grep -v loop | grep -v '^[0-9]' | grep -v '^ram' | head -n 1)"
        if [ -n "$disk_name" ]; then
            local last_part
            last_part="$(ls /sys/class/block/${disk_name}/ 2>/dev/null | grep "^${disk_name}" | sort -V | tail -n 1)"
            if [ -n "$last_part" ]; then
                target_dev="/dev/$last_part"
            fi
        fi
    fi
    if [ -z "$target_dev" ]; then
        log_msg "Could not determine block device. Skipping."
        return 0
    fi

    log_msg "Target block device: $target_dev"

    # Resolve /dev/root or symlinks to actual block device
    if [ "$target_dev" = "/dev/root" ] || [ -L "$target_dev" ]; then
        target_dev="$(readlink -f "$target_dev" 2>/dev/null || echo "$target_dev")"
    fi
    if [ "$target_dev" = "/dev/root" ]; then
        local mm
        mm="$(awk '$5 == "/rom" || $5 == "/" {print $3}' /proc/self/mountinfo 2>/dev/null | head -n 1)"
        if [ -n "$mm" ] && [ -e "/sys/dev/block/$mm" ]; then
            target_dev="/dev/$(basename "$(readlink -f "/sys/dev/block/$mm" 2>/dev/null)")"
        fi
    fi

    # 2. Extract disk and partition numbers safely
    local part="${target_dev##*[^0-9]}"
    if [ -z "$part" ]; then
        log_msg "Could not extract partition number from $target_dev. Skipping."
        return 0
    fi

    local disk="${target_dev%p"$part"}"
    if [ "$disk" = "$target_dev" ]; then
        disk="${target_dev%"$part"}"
    fi
    if [ -z "$disk" ] || [ "$disk" = "$target_dev" ]; then
        log_msg "Could not extract disk path from $target_dev. Skipping."
        return 0
    fi

    log_msg "Disk: $disk  Partition: $part"

    # 3. Check physical sector counts to determine if partition expansion is needed
    local disk_basename="${disk##*/}"
    local part_basename="${target_dev##*/}"
    
    local disk_sectors="$(cat "/sys/class/block/${disk_basename}/size" 2>/dev/null || echo 0)"
    local part_start="$(cat "/sys/class/block/${part_basename}/start" 2>/dev/null || echo 0)"
    local part_sectors="$(cat "/sys/class/block/${part_basename}/size" 2>/dev/null || echo 0)"
    local part_end=$((part_start + part_sectors))
    local free_sectors=$((disk_sectors - part_end))

    log_msg "Disk size: $disk_sectors sectors, partition end: $part_end, free: $free_sectors sectors"

    # If more than ~4MB (8192 sectors of 512B) is unallocated after target partition, expand it
    if [ "$disk_sectors" -gt 0 ] && [ "$free_sectors" -gt 8192 ]; then
        log_msg "Found $((free_sectors / 2048)) MB unallocated disk space. Expanding partition $part on $disk..."

        # Remove any subsequent partitions (e.g. p3, p4 after p2)
        parted -s "$disk" unit s print 2>/dev/null \
            | awk -v p="$part" '$1 ~ /^[0-9]+$/ && $1 > p {print $1}' \
            | while read -r pnum; do
                log_msg "Removing partition $pnum after partition $part..."
                local dev_rm=""
                if [ -e "${disk}p${pnum}" ]; then dev_rm="${disk}p${pnum}"; elif [ -e "${disk}${pnum}" ]; then dev_rm="${disk}${pnum}"; fi
                if [ -n "$dev_rm" ]; then
                    umount -l "$dev_rm" 2>/dev/null || true
                    swapoff "$dev_rm" 2>/dev/null || true
                fi
                parted -s "$disk" rm "$pnum" 2>/dev/null || true
                if [ -n "$dev_rm" ] && command -v partx >/dev/null 2>&1; then
                    partx -d "$dev_rm" 2>/dev/null || true
                fi
              done

        # Notify kernel of partition removals
        partprobe "$disk" 2>/dev/null || partx -u "$disk" 2>/dev/null || true
        sleep 1

        # Fix misplaced or damaged GPT backup header if necessary (e.g. from previous power loss)
        printf "Fix\nOK\nIgnore\n" | parted ---pretend-input-tty "$disk" print >/dev/null 2>&1 || true
        partprobe "$disk" 2>/dev/null || partx -u "$disk" 2>/dev/null || true
        sleep 1

        # Resize target partition to 100%
        parted -s "$disk" resizepart "$part" 100%
        printf "Fix\nOK\nIgnore\n" | parted ---pretend-input-tty "$disk" print >/dev/null 2>&1 || true
        partprobe "$disk" 2>/dev/null || partx -u "$disk" 2>/dev/null || block auto >/dev/null 2>&1 || true
        sleep 1
        log_msg "Partition expansion complete."
    else
        log_msg "Partition already fully allocated (free: $free_sectors sectors). No partition expansion needed."
    fi

    # 4. For direct ext4/ext3/ext2 non-overlay partitions, resize filesystem immediately
    local root_fstype
    root_fstype="$(block info "$target_dev" 2>/dev/null | grep -oE 'TYPE="[^"]+"' | cut -d'"' -f2)"
    if [ -z "$root_fstype" ]; then
        root_fstype="$(awk -v d="$target_dev" '$1 == d {print $3}' /proc/mounts 2>/dev/null | head -n 1)"
    fi

    if [ "$root_fstype" = "ext4" ] || [ "$root_fstype" = "ext3" ] || [ "$root_fstype" = "ext2" ]; then
        if command -v resize2fs >/dev/null 2>&1; then
            log_msg "Direct $root_fstype rootfs detected. Running resize2fs on $target_dev..."
            if ! resize2fs -f "$target_dev" >/dev/null 2>&1; then
                log_msg "Direct $root_fstype rootfs resize failed or dirty on $target_dev. Running e2fsck..."
                if command -v e2fsck >/dev/null 2>&1; then
                    e2fsck -p -f "$target_dev" >/dev/null 2>&1 || e2fsck -y "$target_dev" >/dev/null 2>&1 || true
                fi
                log_msg "Retrying $root_fstype resize after e2fsck..."
                resize2fs -f "$target_dev" >/dev/null 2>&1 || true
            fi
        fi
    fi
}

do_expand_overlay() {
    if [ -f /etc/rootfs-expanded ] || [ -f /overlay/upper/etc/rootfs-expanded ] || [ -f /tmp/overlay/upper/etc/rootfs-expanded ]; then
        return 0
    fi

    # In standard squashfs+overlayfs architecture, the F2FS/ext4 overlay lives on /dev/loop0 after squashfs.
    # In preinit_main (before 80_mount_root), /dev/loop0 DOES NOT EXIST YET.
    # At 80_mount_root, libfstools creates /dev/loop0 spanning the newly expanded partition and mounts it at /tmp/overlay.
    # Here in preinit_mount_root (right after 80_mount_root), loop0 exists so we can cleanly resize it.
    block detect >/dev/null 2>&1 || true
    block info >/dev/null 2>&1 || true

    local dev fstype mountpoint
    for dev in $(block info 2>/dev/null | grep -E 'TYPE="(f2fs|ext[234])"' | cut -d: -f1); do
        fstype="$(block info "$dev" 2>/dev/null | grep -oE 'TYPE="[^"]+"' | cut -d'"' -f2)"
        mountpoint="$(awk -v d="$dev" '$1 == d || $2 == d {print $2}' /proc/mounts 2>/dev/null | head -n 1)"
        if [ -z "$mountpoint" ]; then
            mountpoint="$(block info "$dev" 2>/dev/null | grep -oE 'MOUNT="[^"]+"' | cut -d'"' -f2)"
        fi

        log_msg "Checking overlay filesystem on $dev ($fstype, mount: ${mountpoint:-none})..."

        case "$fstype" in
            f2fs)
                if command -v resize.f2fs >/dev/null 2>&1; then
                    # f2fs strictly requires offline resizing. Since preinit hasn't switched root to procd yet,
                    # unmounting /tmp/overlay is safe and will not fail with device busy.
                    if [ -n "$mountpoint" ] && grep -q " $dev " /proc/mounts 2>/dev/null; then
                        log_msg "Temporarily unmounting $dev from $mountpoint for offline F2FS resize..."
                        umount -l "$dev" 2>/dev/null || umount "$mountpoint" 2>/dev/null || true
                    fi

                    log_msg "Running resize.f2fs on $dev..."
                    if ! resize.f2fs "$dev" >/dev/null 2>&1; then
                        log_msg "f2fs overlay resize failed or dirty on $dev. Running fsck.f2fs..."
                        if command -v fsck.f2fs >/dev/null 2>&1; then
                            fsck.f2fs -a "$dev" >/dev/null 2>&1 || fsck.f2fs -f "$dev" >/dev/null 2>&1 || true
                        fi
                        log_msg "Retrying f2fs overlay resize after fsck..."
                        resize.f2fs "$dev" >/dev/null 2>&1 || true
                    fi

                    # Remount if unmounted
                    if [ -n "$mountpoint" ] && ! grep -q " $dev " /proc/mounts 2>/dev/null; then
                        log_msg "Remounting $dev to $mountpoint..."
                        mount "$dev" "$mountpoint" 2>/dev/null || block mount >/dev/null 2>&1 || true
                    fi
                fi
                ;;
            ext4|ext3|ext2)
                if command -v resize2fs >/dev/null 2>&1; then
                    log_msg "Running resize2fs on $dev..."
                    if ! resize2fs -f "$dev" >/dev/null 2>&1; then
                        log_msg "$fstype overlay resize failed or dirty on $dev. Running e2fsck..."
                        if command -v e2fsck >/dev/null 2>&1; then
                            e2fsck -p -f "$dev" >/dev/null 2>&1 || e2fsck -y "$dev" >/dev/null 2>&1 || true
                        fi
                        log_msg "Retrying $fstype overlay resize after e2fsck..."
                        resize2fs -f "$dev" >/dev/null 2>&1 || true
                    fi
                fi
                ;;
        esac
    done
}

do_mark_rootfs_expanded() {
    touch /etc/rootfs-expanded 2>/dev/null || true
    touch /overlay/upper/etc/rootfs-expanded 2>/dev/null || true
    touch /tmp/overlay/upper/etc/rootfs-expanded 2>/dev/null || true
}

boot_hook_add preinit_main do_expand_rootfs
boot_hook_add preinit_mount_root do_expand_overlay
boot_hook_add preinit_mount_root do_mark_rootfs_expanded
