#!/bin/bash
set -eo pipefail

if [ $# -eq 0 ]; then
    echo "Usage: builder <command> --profile <slug> [args...]"
    echo "Commands: setup, menuconfig, save-config, show-config, build, clean, clean-cache, save-patches"
    exit 1
fi

COMMAND="$1"
shift

export PROFILE=""
export FRESH=0
export DEEP=0
export CLEAN_DL=0
export CLEAN_ALL=0

while [[ $# -gt 0 ]]; do
    case "$1" in
        --profile)
            export PROFILE="$2"
            shift 2
            ;;
        --fresh)
            export FRESH=1
            export FRESH_SETUP=1
            shift
            ;;
        --deep)
            export DEEP=1
            shift
            ;;
        --dl)
            export CLEAN_DL=1
            shift
            ;;
        --all)
            export CLEAN_ALL=1
            shift
            ;;
        --ccache)
            export USE_CCACHE=1
            shift
            ;;
        --fallback)
            export FALLBACK_SINGLE_CORE=1
            shift
            ;;
        *)
            echo "Unknown arg: $1"
            exit 1
            ;;
    esac
done

if [ -d "/app/scripts" ]; then
    export BUILDER_ROOT="/app"
else
    export BUILDER_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
fi

export CCACHE_DIR="/builder/ccache"

if [[ "$COMMAND" == "clean-cache" ]]; then
    if [[ $CLEAN_ALL -eq 1 ]]; then
        rm -rf /builder/ccache/* /builder/dl/* 2>/dev/null || true
        echo "Cleaned ccache and dl cache."
    elif [[ $CLEAN_DL -eq 1 ]]; then
        rm -rf /builder/dl/* 2>/dev/null || true
        echo "Cleaned dl cache."
    else
        rm -rf /builder/ccache/* 2>/dev/null || true
        echo "Cleaned ccache."
    fi
    exit 0
fi

if [[ -z "$PROFILE" ]]; then
    echo "Error: --profile <slug> is required."
    exit 1
fi

if [ -d "/builder/profiles" ]; then
    export PROFILE_DIR="/builder/profiles/$PROFILE"
else
    export PROFILE_DIR="$BUILDER_ROOT/profiles/$PROFILE"
fi
export WORKTREE_DIR="/builder/source/worktrees/$PROFILE"

if [[ ! -d "$PROFILE_DIR" ]]; then
    echo "Error: Profile directory not found: $PROFILE_DIR"
    exit 1
fi

case "$COMMAND" in
    setup)
        "$BUILDER_ROOT/scripts/engine/setup.sh"
        ;;
    menuconfig)
        if [[ ! -d "$WORKTREE_DIR" ]]; then
            echo "Worktree not found. Run builder setup --profile $PROFILE first."
            exit 1
        fi
        cd "$WORKTREE_DIR"
        make menuconfig
        ;;
    save-config)
        "$BUILDER_ROOT/scripts/engine/save-config.sh"
        ;;
    show-config)
        python3 "$BUILDER_ROOT/scripts/engine/show-config.py" "$PROFILE_DIR"
        ;;
    build)
        "$BUILDER_ROOT/scripts/engine/build.sh"
        ;;
    compile)
        "$BUILDER_ROOT/scripts/engine/07-compile.sh"
        ;;
    load-config)
        "$BUILDER_ROOT/scripts/engine/06-load-config.sh"
        ;;
    export-artifacts)
        "$BUILDER_ROOT/scripts/engine/08-export-artifacts.sh"
        ;;
    clean)
        if [[ -d "$WORKTREE_DIR" ]]; then
            git -C /builder/source/main worktree remove -f "$WORKTREE_DIR" || rm -rf "$WORKTREE_DIR"
            echo "Worktree $WORKTREE_DIR removed."
        else
            echo "Worktree $WORKTREE_DIR does not exist."
        fi
        ;;
    save-patches)
        echo "Saving refreshed patches..."
        if [[ -d "$WORKTREE_DIR/patches" ]]; then
            mkdir -p "$PROFILE_DIR/patches/source"
            for patch in "$WORKTREE_DIR/patches/"*; do
                if [[ -f "$patch" ]]; then
                    cp "$patch" "$PROFILE_DIR/patches/source/"
                    echo "Saved $(basename "$patch")"
                fi
            done
        else
            echo "No patches directory found in worktree: $WORKTREE_DIR/patches"
        fi
        ;;
    *)
        echo "Unknown command: $COMMAND"
        exit 1
        ;;
esac
